((TEMPLATE :N "1. Einzelbüro_Std._Licht" :T LIGHT :D "Definierte Wärmeabgabe, basierend auf spez. elektr. Bewertungsleistung. Relative Abwesenheit C_A und die Gebäudebetriebszeit F_t werden im Zeitplan berücksichtigt.
Nennleistung basiert auf spezifischer elektr. Beleuchtungsleistung, ermittelt nach Tabellenverfahren für direkte Beleuchtung gem. Gleichung (11) DIN V 18599-4 und Tab. 5 DIN V 18599-10 (Raumindex k) für Sonstige LEDs in LED-Leuchten gem. Tab. 6 DIN V 18599-4.")
 (:PAR :N CONTROL :V SETPOINTS+SCHEDULE)
 (:PAR :N RATED_INPUT :V 8.6)
 (:PAR :N LUMINOUS_EFFICIENY :V 100 :S (:DEFAULT NIL 2))
 (:PAR :N CONVECTIVE_FRACTION :V 0.3)
 (:RES :N SCHEDULE_0-1 :V "1. Einzelbüro_LichtProfil")
 (:PAR :N ACCOUNT :V :DEFAULT))
((ZONE-DEFAULTS :N "1. Einzelbüro" :T ZONE-DEFAULTS)
 ((SETPOINT_COLLECTION :N LOCAL_SETPOINTS)
  (:PAR :N MIN_VENT_AIR :V 0.3)
  (:PAR :N MAX_VENT_AIR :V 7)
  (:PAR :N THERMOSTAT_MIN :V 21)
  (:PAR :N THERMOSTAT_MAX :V 25)
  (:PAR :N DESIGN_MIN :V 19 :S (:DEFAULT NIL 2))
  (:PAR :N DESIGN_MAX :V 30 :S (:DEFAULT NIL 2))
  (:PAR :N MIN_HUMIDITY :V 20)
  (:PAR :N MAX_HUMIDITY :V 80)
  (:PAR :N MIN_CO2 :V 700)
  (:PAR :N MAX_CO2 :V 1100)
  (:PAR :N MIN_LIGHT :V 100)
  (:PAR :N MAX_LIGHT :V 10000))
 ((AGGREGATE :N GEOMETRY)
  (:PAR :N Z :V 3))
 ((AGGREGATE :N CENTRAL-AHU)
  (:PAR :N SYSTEM_TYPE :V (SCHEDULE "1. Einzelbüro_RLT"))
  (:PAR :N CAV_VENT_AIR :F 2592 :V 1.111)
  (:PAR :N CAV_VENT_SUP :F 2592 :V 1.111))
 (:RES :N SETPOINTS :V "1. Einzelbüro_Std._Control_01")
 (:PAR :N EQUIP-ACCOUNT :V NIL :S (:DEFAULT NIL 2))
 (:PAR :N LIGHT-ACCOUNT :V "Beleuchtung" :S (:DEFAULT NIL2))
 (:TRES :N WINDOWS :V WINDOW)
 ((AGGREGATE :N OCCUPANT)
  (:PAR :N NUMBER_OF :V 0.071)
  (:TRES :N LOAD_TYPE :V "1. Einzelbüro_Std._Pers")
  (:RES :N SCHEDULE_0-1 :V "1. Einzelbüro_PersProfil"))
 ((AGGREGATE :N EQUIPMENT)
  (:PAR :N NUMBER_OF :V 1)
  (:TRES :N LOAD_TYPE :V "1. Einzelbüro_Std._Geräte")
  (:RES :N SCHEDULE_0-1 :V "1. Einzelbüro_GeräteProfil"))
 ((AGGREGATE :N LIGHT)
  (:PAR :N NUMBER_OF :V 1)
  (:TRES :N LOAD_TYPE :V "1. Einzelbüro_Std._Licht")
  (:RES :N SCHEDULE_0-1 :V "1. Einzelbüro_LichtProfil"))
 (:PAR :N FURNITURE_AREA_FRACTION :V 0.2)
 (:PAR :N FURNITURE_WEIGHT :V 25)
 (:PAR :N COOLING-POWER :V 200)
